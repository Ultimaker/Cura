!define MUI_COMPONENTSPAGE_TEXT_TOP "Select the file types you want ${APP_NAME} to open when double-clicked. Unchecked types will keep their current default application. This cannot override previous User-Choices through Always Open With."
!define MUI_COMPONENTSPAGE_TEXT_COMPLIST "File type associations:"
!define MUI_COMPONENTSPAGE_SMALLDESC
!insertmacro MUI_PAGE_COMPONENTS
!ifdef MUI_PAGE_HEADER_TEXT
  !undef MUI_PAGE_HEADER_TEXT
!endif
!ifdef MUI_PAGE_HEADER_SUBTEXT
  !undef MUI_PAGE_HEADER_SUBTEXT
!endif
!ifdef MUI_COMPONENTSPAGE_TEXT_TOP
  !undef MUI_COMPONENTSPAGE_TEXT_TOP
!endif
!ifdef MUI_COMPONENTSPAGE_TEXT_COMPLIST
  !undef MUI_COMPONENTSPAGE_TEXT_COMPLIST
!endif
!ifdef MUI_COMPONENTSPAGE_SMALLDESC
  !undef MUI_COMPONENTSPAGE_SMALLDESC
!endif

!insertmacro MUI_PAGE_INSTFILES

# Launch via explorer so Cura runs non-elevated.
!define MUI_FINISHPAGE_RUN "$WINDIR\explorer.exe"
!define MUI_FINISHPAGE_RUN_PARAMETERS "$INSTDIR\${MAIN_APP_EXE}"

!define MUI_FINISHPAGE_SHOWREADME ""
!define MUI_FINISHPAGE_SHOWREADME_TEXT "Create a desktop shortcut"
!define MUI_FINISHPAGE_SHOWREADME_NOTCHECKED
!define MUI_FINISHPAGE_SHOWREADME_FUNCTION createDesktopShortcut
!insertmacro MUI_PAGE_FINISH

!insertmacro MUI_UNPAGE_CONFIRM

!insertmacro MUI_UNPAGE_INSTFILES

!insertmacro MUI_UNPAGE_FINISH

!insertmacro MUI_LANGUAGE "English"

######################################################################

Function createDesktopShortcut
    CreateShortCut "$DESKTOP\${APP_NAME}.lnk" "$INSTDIR\${MAIN_APP_EXE}"
FunctionEnd

######################################################################

Section -MainProgram
${INSTALL_TYPE}
SetOverwrite try
{% for out_path, files in mapped_out_paths.items() %}SetOutPath "{{ out_path }}"{% for file in files %}
File "{{ file[0] }}"{% endfor %}
{% endfor %}SectionEnd

######################################################################

SectionGroup "File Associations" SEC_FILEASSOC

Section "*.STL files" SEC_STL
!insertmacro APP_ASSOCIATE "stl" "Cura.model" "Standard Tessellation Language (STL) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.3MF files" SEC_3MF
!insertmacro APP_ASSOCIATE "3mf" "Cura.project" "3D Manufacturing Format (3MF) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.OBJ files" SEC_OBJ
!insertmacro APP_ASSOCIATE "obj" "Cura.obj" "Wavefront OBJ files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.PLY files" SEC_PLY
!insertmacro APP_ASSOCIATE "ply" "Cura.ply" "Stanford Triangle Format (PLY) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.DAE files" SEC_DAE
!insertmacro APP_ASSOCIATE "dae" "Cura.dae" "COLLADA (DAE) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.GLTF files" SEC_GLTF
!insertmacro APP_ASSOCIATE "gltf" "Cura.gltf" "glTF JSON files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.GLB files" SEC_GLB
!insertmacro APP_ASSOCIATE "glb" "Cura.glb" "glTF Binary files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.AMF files" SEC_AMF
!insertmacro APP_ASSOCIATE "amf" "Cura.amf" "Additive Manufacturing Format (AMF) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section "*.X3D files" SEC_X3D
!insertmacro APP_ASSOCIATE "x3d" "Cura.x3d" "X3D files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section /o "*.UFP files" SEC_UFP
!insertmacro APP_ASSOCIATE "ufp" "Cura.ufp" "UltiMaker Format Package (UFP) files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

Section /o "*.GCODE files" SEC_GCODE
!insertmacro APP_ASSOCIATE "gcode" "Cura.gcode" "G-code files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
!insertmacro APP_ASSOCIATE "g" "Cura.gcode" "G-code files" "$INSTDIR\${MAIN_APP_EXE},0" "Open with {{ app_name }}" "$\"$INSTDIR\${MAIN_APP_EXE}$\" $\"%1$\""
SectionEnd

SectionGroupEnd

SectionGroup "URL Protocols" SEC_URLPROTOCOL

Section "cura://" SEC_URLPROTOCOL_CURA
WriteRegStr HKCR "cura" "" "URL:cura"
WriteRegStr HKCR "cura" "URL Protocol" ""
WriteRegStr HKCR "cura\DefaultIcon" "" "$INSTDIR\${MAIN_APP_EXE},1"
WriteRegStr HKCR "cura\shell\open\command" "" '"$INSTDIR\${MAIN_APP_EXE}" "%1"'
SectionEnd

Section /o "slicer://" SEC_URLPROTOCOL_SLICER
WriteRegStr HKCR "slicer" "" "URL:slicer"
WriteRegStr HKCR "slicer" "URL Protocol" ""
WriteRegStr HKCR "slicer\DefaultIcon" "" "$INSTDIR\${MAIN_APP_EXE},1"
WriteRegStr HKCR "slicer\shell\open\command" "" '"$INSTDIR\${MAIN_APP_EXE}" "%1"'
SectionEnd

SectionGroupEnd

######################################################################

Section -UpdateApplicationsRegistry
; Update the Applications key for "Open With" to point to current version (only once)
WriteRegStr HKCR "Applications\${MAIN_APP_EXE}\shell\open\command" "" '"$INSTDIR\${MAIN_APP_EXE}" "%1"'
WriteRegStr HKCU "SOFTWARE\Classes\Applications\${MAIN_APP_EXE}\shell\open\command" "" '"$INSTDIR\${MAIN_APP_EXE}" "%1"'

; Register capabilities so Cura appears in Windows "Default apps" / "Set Default Programs"
!define CAPS_KEY "SOFTWARE\${COMP_NAME}\${APP_NAME}\Capabilities"
WriteRegStr HKLM "${CAPS_KEY}" "ApplicationName" "${APP_NAME}"
WriteRegStr HKLM "${CAPS_KEY}" "ApplicationDescription" "UltiMaker Cura is the world's most trusted 3D printing slicer."
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".stl"    "Cura.model"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".3mf"    "Cura.project"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".obj"    "Cura.obj"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".ply"    "Cura.ply"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".dae"    "Cura.dae"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".gltf"   "Cura.gltf"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".glb"    "Cura.glb"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".amf"    "Cura.amf"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".x3d"    "Cura.x3d"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".ufp"    "Cura.ufp"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".gcode"  "Cura.gcode"
WriteRegStr HKLM "${CAPS_KEY}\FileAssociations" ".g"      "Cura.gcode"
WriteRegStr HKLM "${CAPS_KEY}\URLAssociations"  "cura"    "cura"
WriteRegStr HKLM "${CAPS_KEY}\URLAssociations"  "slicer"  "slicer"
WriteRegStr HKLM "SOFTWARE\RegisteredApplications" "${APP_NAME}" "${CAPS_KEY}"
!undef CAPS_KEY
SectionEnd

Section -Icons_Reg
SetOutPath "$INSTDIR"
WriteUninstaller "$INSTDIR\uninstall.exe"

CreateShortCut "$SMPROGRAMS\${APP_NAME}.lnk" "$INSTDIR\${MAIN_APP_EXE}"

WriteRegStr ${REG_ROOT} "${REG_APP_PATH}" "" "$INSTDIR\${MAIN_APP_EXE}"
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "DisplayName" "${APP_NAME}"
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "UninstallString" "$INSTDIR\uninstall.exe"
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "QuietUninstallString" '"$INSTDIR\uninstall.exe" /S'
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "DisplayIcon" "$INSTDIR\${MAIN_APP_EXE}"
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "DisplayVersion" "${VERSION}"
WriteRegStr ${REG_ROOT} "${UNINSTALL_PATH}"  "Publisher" "${COMP_NAME}"

; Notify the Windows shell that file associations have changed
!insertmacro UPDATEFILEASSOC

SectionEnd

######################################################################

; Section descriptions
!insertmacro MUI_FUNCTION_DESCRIPTION_BEGIN
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_FILEASSOC} "Associate 3D model file types with {{ app_name }}"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_STL} "Associate .STL (Standard Tessellation Language) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_3MF} "Associate .3MF (3D Manufacturing Format) project files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_OBJ} "Associate .OBJ (Wavefront Object) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_PLY} "Associate .PLY (Stanford Triangle Format) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_DAE} "Associate .DAE (COLLADA) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_GLTF} "Associate .GLTF (GL Transmission Format) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_GLB} "Associate .GLB (GL Transmission Format Binary) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_AMF} "Associate .AMF (Additive Manufacturing Format) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_X3D} "Associate .X3D (Extensible 3D) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_UFP} "Associate .UFP (UltiMaker Format Package) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_GCODE} "Associate .GCODE and .G (G-code) files"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_URLPROTOCOL} "Enable opening models directly from web links via URL protocols"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_URLPROTOCOL_CURA} "Register the cura:// URL protocol"
  !insertmacro MUI_DESCRIPTION_TEXT ${SEC_URLPROTOCOL_SLICER} "Register the slicer:// URL protocol"
!insertmacro MUI_FUNCTION_DESCRIPTION_END

######################################################################

Section Uninstall
${INSTALL_TYPE}{% for files in mapped_out_paths.values() %}{% for file in files %}
Delete "{{ file[1] }}"{% endfor %}{% endfor %}{% for rem_dir in rmdir_paths %}
RmDir "{{ rem_dir }}"{% endfor %}

# FIXME: dirty solution, but for some reason these directories aren't removed
RmDir "$INSTDIR\share\cura\resources\scripts"
RmDir "$INSTDIR\share\cura\resources"
RmDir "$INSTDIR\share\cura"
RmDir "$INSTDIR\share\uranium\resources\scripts"
RmDir "$INSTDIR\share\uranium\resources"
RmDir "$INSTDIR\share\uranium"
RmDir "$INSTDIR\share"

Delete "$INSTDIR\uninstall.exe"

; Safety net to ensure files have been removed
RmDir /r /REBOOTOK "$INSTDIR"

Delete "$SMPROGRAMS\${APP_NAME}.lnk"
Delete "$DESKTOP\${APP_NAME}.lnk"

; Unassociate all file types
!insertmacro APP_UNASSOCIATE "stl" "Cura.model"
!insertmacro APP_UNASSOCIATE "3mf" "Cura.project"
!insertmacro APP_UNASSOCIATE "obj" "Cura.obj"
!insertmacro APP_UNASSOCIATE "ply" "Cura.ply"
!insertmacro APP_UNASSOCIATE "dae" "Cura.dae"
!insertmacro APP_UNASSOCIATE "gltf" "Cura.gltf"
!insertmacro APP_UNASSOCIATE "glb" "Cura.glb"
!insertmacro APP_UNASSOCIATE "amf" "Cura.amf"
!insertmacro APP_UNASSOCIATE "x3d" "Cura.x3d"
!insertmacro APP_UNASSOCIATE "ufp" "Cura.ufp"
!insertmacro APP_UNASSOCIATE "gcode" "Cura.gcode"
!insertmacro APP_UNASSOCIATE "g" "Cura.gcode"

; Clean up Applications registry entries
DeleteRegKey HKCR "Applications\${MAIN_APP_EXE}"
DeleteRegKey HKCU "SOFTWARE\Classes\Applications\${MAIN_APP_EXE}"

; Remove RegisteredApplications / Capabilities entries
DeleteRegValue HKLM "SOFTWARE\RegisteredApplications" "${APP_NAME}"
DeleteRegKey HKLM "SOFTWARE\${COMP_NAME}\${APP_NAME}"

; Unassociate file associations for 'cura' protocol
DeleteRegKey HKCR "cura"

; Unassociate file associations for 'slicer' protocol
DeleteRegKey HKCR "slicer"

; Notify the Windows shell that file associations have been removed
!insertmacro UPDATEFILEASSOC

DeleteRegKey ${REG_ROOT} "${REG_APP_PATH}"
DeleteRegKey ${REG_ROOT} "${UNINSTALL_PATH}"
SectionEnd

